{
  "name": "freeos",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently -n API,DASHBOARD -c cyan,magenta \"npm run dev:api\" \"npm run dev:dashboard\"",
    "dev:api": "npm run dev --workspace @freeos/api-server",
    "dev:dashboard": "npm run dev --workspace @freeos/dashboard",
    "build": "npm run build --workspaces --if-present",
    "build:api": "npm run build --workspace @freeos/api-server",
    "build:dashboard": "npm run build --workspace @freeos/dashboard",
    "check:ollama": "node tools/scripts/check-ollama.js",
    "check:searxng": "node tools/scripts/check-searxng.js",
    "check:voice": "npm run build --workspace @freeos/voice-core && node tools/scripts/check-voice.js",
    "setup:folders": "node tools/scripts/create-local-folders.js",
    "setup:whisper-folders": "node tools/scripts/setup-whisper-folders.js",
    "init:memory": "npm run build --workspace @freeos/memory-core && node tools/scripts/init-memory.js",
    "init:voice": "npm run build --workspace @freeos/memory-core && npm run build --workspace @freeos/voice-core && node tools/scripts/init-voice.js",
    "init:tools": "npm run build --workspace @freeos/memory-core && npm run build --workspace @freeos/voice-core && npm run build --workspace @freeos/tool-runner && node tools/scripts/init-tools.js",
    "init:rag": "npm run build --workspace @freeos/rag-core && node tools/scripts/init-rag.js",
    "tools:status": "npm run build --workspace @freeos/tool-runner && node tools/scripts/tools-status.js",
    "memory:status": "npm run build --workspace @freeos/memory-core && node tools/scripts/memory-status.js",
    "research:status": "npm run build --workspace @freeos/memory-core && npm run build --workspace @freeos/research-core && node tools/scripts/research-status.js",
    "rag:status": "npm run build --workspace @freeos/rag-core && node tools/scripts/rag-status.js",
    "rag:index": "npm run build --workspace @freeos/rag-core && node tools/scripts/rag-index.js",
    "command:status": "node tools/scripts/command-status.js",
    "backup:freeos": "node tools/scripts/backup-freeos.js",
    "smoke:test": "node tools/scripts/smoke-test.js",
    "env:check": "node tools/scripts/env-check.js",
    "db:integrity": "node tools/scripts/db-integrity.js",
    "backup:verify": "node tools/scripts/verify-backup.js",
    "release:check": "node tools/scripts/release-check.js"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  },
  "engines": {
    "node": ">=20"
  }
}
